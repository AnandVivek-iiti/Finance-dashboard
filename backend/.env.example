# Neon (or any Postgres) connection string, e.g.:
# postgresql://user:password@ep-xxxx.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/finance_dashboard
# Set to "disable" only for a local Postgres with no SSL configured.
# PGSSL=disable

PORT=5000

PYTHON_BIN=python

NODE_ENV=development

FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>.apps.googleusercontent.com
# GROQ_API_KEY can hold one key or a comma-separated list for rotation/rate-limit fallback:
# GROQ_API_KEY=key1,key2,key3
GROQ_API_KEY=your-groq-api-key-here

# Optional tuning (see README for what each does):
# GROQ_OCR_MODEL=qwen/qwen3.6-27b
# GROQ_FALLBACK_MODEL=openai/gpt-oss-120b
# GROQ_OCR_MAX_TOKENS=4000
# GROQ_FALLBACK_MAX_TOKENS=3000
# GROQ_FALLBACK_ROWS_PER_CHUNK=40
# GROQ_FALLBACK_CHUNK_DELAY_MS=500

JWT_SECRET=

# COOKIE_DOMAIN=
