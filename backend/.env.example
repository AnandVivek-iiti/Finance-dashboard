MONGO_URI=mongodb://127.0.0.1:27017/finance_dashboard
PORT=5000

PYTHON_BIN=python

NODE_ENV=development

# Comma-separated list of allowed frontend origins (no trailing slash).
# In production this should be your deployed frontend URL, e.g.
# https://finance-dashboard-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Google OAuth client ID (same value as frontend's VITE_GOOGLE_CLIENT_ID).
# Create it at https://console.cloud.google.com/ -> APIs & Services -> Credentials.
GOOGLE_CLIENT_ID=

# Secret used to sign the app's own session JWT. Generate with:
#   openssl rand -base64 32
JWT_SECRET=

# Optional: only needed if you want the session cookie shared across
# subdomains of a common parent domain. Leave blank otherwise.
COOKIE_DOMAIN=
